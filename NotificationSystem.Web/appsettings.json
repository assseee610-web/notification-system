{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=notificationdb;Username=postgres;Password=12345"
  },
  "Jwt": {
    "Key": "MySuperSecretKey1234567890!@#$%^&*()",
    "Issuer": "NotificationSystem",
    "Audience": "NotificationSystemUsers",
    "ExpireMinutes": 60
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "UserName": "guest",
    "Password": "guest",
    "Port": 5672,
    "EmailQueue": "email_queue",
    "SmsQueue": "sms_queue",
    "PushQueue": "push_queue"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "DefaultExpirationMinutes": 5
  },
  "Archiving": {
    "RetentionDays": 30,
    "CleanupIntervalHours": 24
  }
}